{
  "name": "ai-agent-backend",
  "version": "1.0.0",
  "description": "AI Voice Agent SaaS Backend",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "dev": "dotenv -e .env concurrently \"npm run dev:node\" \"npm run dev:embed\"",
    "dev:node": "nodemon src/app.js",
    "dev:embed": "$PYTHON_PATH -m uvicorn src.services.embedding_service:app --host 0.0.0.0 --port $EMBEDDING_SERVICE_PORT",
    "start": "node src/app.js"
  },
  "keywords": [
    "ai",
    "saas",
    "voice-agent",
    "fastify"
  ],
  "author": "Om Vilas Shinde",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.1",
    "dotenv-cli": "^11.0.0",
    "fastify": "^5.8.4",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "sarvamai": "^1.1.6"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
